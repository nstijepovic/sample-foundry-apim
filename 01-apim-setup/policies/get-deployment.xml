<!--
  GetDeployment Policy
  
  Returns model details for a specific deployment.
  Foundry calls this to validate a model exists.
  
  NOTE: Using static response instead of C# expression to avoid
  validation issues with az rest. Update the model name as needed.
-->
<policies>
    <inbound>
        <base />
        <return-response>
            <set-status code="200" reason="OK" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-body>{"name": "gpt-5", "properties": {"model": {"format": "OpenAI", "name": "gpt-5", "version": ""}}}</set-body>
        </return-response>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
