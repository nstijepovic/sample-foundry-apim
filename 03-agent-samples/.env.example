# Environment Configuration
# Copy this file to .env and update the values

# Azure AI Foundry Project
AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Connection and Model
AZURE_AI_CONNECTION_NAME=compass-connection
AZURE_AI_MODEL_NAME=gpt-5

# Agent (for chat_with_agent.py)
AZURE_AI_AGENT_NAME=my-compass-agent

# Authentication: Uses DefaultAzureCredential which picks up your 'az login' session.
# No need for AZURE_TENANT_ID unless you have multi-tenant scenarios.
