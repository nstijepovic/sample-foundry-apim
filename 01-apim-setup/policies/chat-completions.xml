<!--
  ChatCompletions Policy
  
  Forwards chat completion requests to the backend LLM.
  Adds the external LLM API key to the request.
  
  IMPORTANT: Replace YOUR_EXTERNAL_LLM_API_KEY with your actual API key.
  
  For production, consider using:
  - Named Values: https://learn.microsoft.com/en-us/azure/api-management/api-management-howto-properties
  - Key Vault: https://learn.microsoft.com/en-us/azure/api-management/api-management-howto-use-azure-key-vault
-->
<policies>
    <inbound>
        <base />
        <!-- Add the external LLM API key -->
        <set-header name="api-key" exists-action="override">
            <value>YOUR_EXTERNAL_LLM_API_KEY</value>
        </set-header>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
